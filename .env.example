# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5050
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
BASE_URL=http://localhost:5050

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=crm
DB_CONNECTION_LIMIT=10

# ============================================
# JWT CONFIGURATION
# ============================================
# CRITICAL: Generate a strong random string (min 32 chars) in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ============================================
# SESSION & CSRF CONFIGURATION
# ============================================
# Used for CSRF token encryption (can be same as JWT_SECRET)
SESSION_SECRET=your-session-secret-change-this-in-production

# ============================================
# RBAC CONFIGURATION
# ============================================
# Super Admin role ID - only this role bypasses approval workflow
# Change this if your Super Admin role has a different ID in the database
SUPER_ADMIN_ROLE_ID=5

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Rate limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Password hashing (bcrypt rounds)
BCRYPT_ROUNDS=10

# Force HTTPS in production
FORCE_HTTPS=false

# ============================================
# RECAPTCHA CONFIGURATION
# ============================================
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=10485760

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Change JWT_SECRET to 32+ character random string
# [ ] Change SESSION_SECRET to random string
# [ ] Set CORS_ORIGIN to your frontend domain (not *)
# [ ] Set NODE_ENV=production
# [ ] Set FORCE_HTTPS=true (if using HTTPS)
# [ ] Update DB credentials
# [ ] Set LOG_LEVEL=warn or error
# [ ] Run: npm audit fix
# [ ] Test all security features
